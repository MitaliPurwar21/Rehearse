# Copy to .env and fill in. .env is gitignored.

# Which provider the judge / smoke test uses: "claude" (strong, paid) or
# "groq" (free, for wiring checks only — do not calibrate on a weak free model).
JUDGE_PROVIDER=claude

# Fill in the key for whichever provider you chose above.
ANTHROPIC_API_KEY=     # needed when JUDGE_PROVIDER=claude
GROQ_API_KEY=          # needed when JUDGE_PROVIDER=groq  (free key, no card)

# Models (defaults shown; override if you want)
JUDGE_MODEL=claude-sonnet-4-6        # used when JUDGE_PROVIDER=claude
GROQ_MODEL=llama-3.3-70b-versatile   # used when JUDGE_PROVIDER=groq
JUDGE_TEMPERATURE=0.0
JUDGE_MAX_TOKENS=4096

# Observability (Phase 5)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
