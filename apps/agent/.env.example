# Copy to .env.local and fill in. .env.local is gitignored.

# LiveKit (free tier at livekit.io) — from your project settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Interviewer voice: Groq runs the LLM, Deepgram does speech-to-text + text-to-speech
GROQ_API_KEY=
DEEPGRAM_API_KEY=

# The Rehearse backend this agent reads competencies from and posts the transcript to
REHEARSE_API_URL=http://localhost:8000
# Which job to interview for. Leave blank when starting interviews from the web app
# (the job id comes from the room name). Only set it for standalone console testing.
REHEARSE_JOB_ID=
